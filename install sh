#!/usr/bin/env bash

set -euo pipefail

LOGFILE="$HOME/Downloads/comfyui_install_log.txt"
exec > >(tee "$LOGFILE") 2>&1

echo "=== ComfyUI Portable Installer (Pop!_OS Cosmic + NVIDIA RTX) ==="
echo "Logging to: $LOGFILE"
echo ""

ROOT_DIR="$HOME/Downloads/ComfyUI Portable Pop OS Cosmic"
COMFY_REPO="https://github.com/comfyanonymous/ComfyUI.git"

echo "[1/6] Creating install folder:"
mkdir -p "$ROOT_DIR"
cd "$ROOT_DIR"

echo "[2/6] Updating system..."
sudo apt update && sudo apt upgrade -y

echo "[3/6] Installing dependencies..."
sudo apt install -y python3 python3-venv python3-pip git wget

echo "[4/6] Creating virtual environment..."
python3 -m venv "$ROOT_DIR/venv"
source "$ROOT_DIR/venv/bin/activate"
pip install --upgrade pip

echo "[5/6] Installing CUDA-enabled PyTorch..."
pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

echo "[6/6] Cloning ComfyUI..."
if [ ! -d "$ROOT_DIR/ComfyUI" ]; then
    git clone "$COMFY_REPO" "$ROOT_DIR/ComfyUI"
fi

echo "Installing ComfyUI dependencies..."
cd "$ROOT_DIR/ComfyUI"
pip install -r requirements.txt

cd "$ROOT_DIR"

cat << 'EOF' > run.sh
#!/usr/bin/env bash
DIR="$(cd "$(dirname "$0")" && pwd)"
source "$DIR/venv/bin/activate"
cd "$DIR/ComfyUI"
python3 main.py --listen --port 8188
EOF

chmod +x run.sh

cat << 'EOF' > update.sh
#!/usr/bin/env bash
DIR="$(cd "$(dirname "$0")" && pwd)"
source "$DIR/venv/bin/activate"

echo "=== Updating ComfyUI ==="
cd "$DIR/ComfyUI"

git pull
pip install -r requirements.txt

echo "Update complete."
EOF

chmod +x update.sh

echo ""
echo "=== Installation Complete ==="
echo "Location:"
echo "  $ROOT_DIR"
echo ""
echo "Run ComfyUI with:"
echo "  ./run.sh"
echo ""
echo "Update ComfyUI anytime with:"
echo "  ./update.sh"
echo ""
echo "If anything went wrong, check:"
echo "  $LOGFILE"
